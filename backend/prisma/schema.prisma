generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Hotel {
  id       Int      @id @default(autoincrement())
  name     String
  image    String[]
  price    Float
  date     DateTime @default(now())
  bonus    String?
  warning  String?
  features String[]
}

model House {
  id       Int      @id @default(autoincrement())
  name     String
  image    String[]
  price    Float
  features String[]
  warning  String?
  bonus    String?
  date     DateTime @default(now())
}

model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  createdAt  DateTime @default(now())
  checkIn    DateTime
  checkOut   DateTime
  name       String
  phone      String
  roomName   String?
  image      String?
  price      Float    @default(0)
  totalPrice Float    @default(0)
  guests     Int      @default(0)
  status     String?  @default("pending")
  houseName  String?
  user       User     @relation(fields: [userId], references: [id])
}
